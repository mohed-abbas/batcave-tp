# Copiez ce fichier en .env et remplissez les valeurs.
PORT=3000
# Clé de signature des JWT (ex: node -e "console.log(require(\047crypto\047).randomBytes(32).toString(\047hex\047))")
JWT_SECRET=changez_moi_par_une_cle_aleatoire

# URL publique du serveur, utilisée pour construire les callback OAuth.
# En production, mettez l'URL HTTPS réelle.
BASE_URL=http://localhost:3000

# Connexion externe OAuth2 / OpenID Connect.
# Chaque provider ne s'active que si SES DEUX clés sont renseignées ; laissez vide
# pour désactiver. Callback à déclarer chez le provider : <BASE_URL>/auth/<provider>/callback

# GitHub  -> https://github.com/settings/developers (New OAuth App)
#            Authorization callback URL : http://localhost:3000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google  -> https://console.cloud.google.com/apis/credentials (OAuth client ID, type Web)
#            Authorized redirect URI : http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord -> https://discord.com/developers/applications (OAuth2)
#            Redirect : http://localhost:3000/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
